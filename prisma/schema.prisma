generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/config/database/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  accounts        Account[]
  categories      Category[]
  movements       Movement[]
  groups          Group[]
  exercises       Exercise[]
  routines        Routine[]
  workoutSessions WorkoutSession[]

  @@map("users")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  userId      String   @map("user_id")
  isActive    Boolean  @default(true) @map("is_active")
  budgetCents Decimal? @db.Decimal(14, 2) @map("budget_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@unique([name, userId])
  @@index([userId])
  @@map("groups")
}

model Account {
  id               String   @id @default(uuid())
  name             String
  type             String
  userId           String   @map("user_id")
  isActive         Boolean  @default(true) @map("is_active")
  isPrincipal      Boolean  @default(false) @map("is_principal")
  creditLimitCents Decimal? @db.Decimal(14, 2) @map("credit_limit_cents")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements         Movement[] @relation("MovementSourceAccount")
  incomingTransfers Movement[] @relation("MovementDestinationAccount")

  @@index([userId])
  @@map("accounts")
}

model Category {
  id           String   @id @default(uuid())
  name         String
  icon         String
  movementType String   @map("movement_type")
  userId       String   @map("user_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@unique([name, movementType, userId])
  @@index([userId])
  @@map("categories")
}

model Movement {
  id           String   @id @default(uuid())
  amount       Decimal  @db.Decimal(14, 2)
  date         DateTime
  note         String?
  accountId    String   @map("account_id")
  toAccountId  String?  @map("to_account_id")
  categoryId   String   @map("category_id")
  movementType String   @map("movement_type")
  groupId      String?  @map("group_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account   Account  @relation("MovementSourceAccount", fields: [accountId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  toAccount Account? @relation("MovementDestinationAccount", fields: [toAccountId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([toAccountId])
  @@index([categoryId])
  @@index([groupId])
  @@index([date])
  @@index([userId])
  @@map("movements")
}

model Exercise {
  id               String   @id @default(uuid())
  userId           String?  @map("user_id")
  name             String
  category         String?
  bodyPart         String?  @map("body_part")
  equipment        String?
  target           String?
  muscleGroup      String?  @map("muscle_group")
  secondaryMuscles String[] @map("secondary_muscles")
  instructions     Json?
  image            String?
  gifUrl           String?  @map("gif_url")
  attribution      String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineExercises RoutineExercise[]
  sessionExercises WorkoutSessionExercise[]

  @@index([userId])
  @@map("exercises")
}

model Routine {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]
  sessions  WorkoutSession[]

  @@unique([name, userId])
  @@index([userId])
  @@map("routines")
}

model RoutineExercise {
  id                String   @id @default(uuid())
  routineId         String   @map("routine_id")
  exerciseId        String   @map("exercise_id")
  order             Int
  targetSets        Int      @map("target_sets")
  targetReps        Int      @map("target_reps")
  targetWeightGrams Int      @map("target_weight_grams")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([routineId])
  @@index([exerciseId])
  @@map("routine_exercises")
}

model WorkoutSession {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  routineId  String    @map("routine_id")
  date       DateTime
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine   Routine                  @relation(fields: [routineId], references: [id], onDelete: Restrict)
  exercises WorkoutSessionExercise[]

  @@index([userId])
  @@index([routineId])
  @@map("workout_sessions")
}

model WorkoutSessionExercise {
  id                String   @id @default(uuid())
  workoutSessionId  String   @map("workout_session_id")
  exerciseId        String   @map("exercise_id")
  actualSets        Int      @map("actual_sets")
  actualReps        Int      @map("actual_reps")
  actualWeightGrams Int      @map("actual_weight_grams")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([workoutSessionId])
  @@index([exerciseId])
  @@map("workout_session_exercises")
}
